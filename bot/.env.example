# Бот читает те же переменные, что и backend (можно один общий .env).
BOT_TOKEN=
MINIAPP_URL=https://your-tma.netlify.app
# Внутренний URL backend (бот и backend обычно на одном сервере)
BOT_API_URL=http://127.0.0.1:8000
# Общий секрет с backend для /api/internal/* (должен совпадать)
INTERNAL_SECRET=
