# ============ Telegram ============
# Токен бота из @BotFather
BOT_TOKEN=
# Chat ID администратора (куда падают уведомления о новых заказах)
ADMIN_CHAT_ID=

# ============ URLs ============
# URL задеплоенной мини-аппки (Netlify) — кнопка в боте
MINIAPP_URL=https://your-tma.netlify.app
# Публичный URL backend (нужен мини-аппке и ссылке тестовой оплаты)
API_BASE_URL=https://your-backend.example.com

# ============ Админ-дашборд ============
# Пароль для входа в дашборд
ADMIN_PASSWORD=
# Токен, которым дашборд авторизует запросы к /api/admin/* (сгенерируй случайный, напр. через `openssl rand -hex 32`)
ADMIN_TOKEN=

# ============ Бот <-> Backend ============
# Внутренний URL backend для бота (обычно локальный)
BOT_API_URL=http://127.0.0.1:8000
# Общий секрет для /api/internal/* (сгенерируй случайный)
INTERNAL_SECRET=

# ============ Прочее ============
# Путь к файлу БД (относительно папки backend/)
DATABASE_PATH=data/shop.sqlite3
# Разрешённые источники CORS через запятую; * — только для локальной разработки
CORS_ORIGINS=*
# Максимальный возраст Telegram initData в секундах (защита от переиспользования подписи)
INITDATA_MAX_AGE=86400

# ============ Способы оплаты ============
# Режим эмуляции оплаты (демо, без реального платёжного шлюза): true/false
PAYMENTS_MOCK=false
# Криптооплата (пусто = способ выключен)
CRYPTO_ADDRESS=
CRYPTO_NETWORK=USDT (TRC20)
# Реквизиты для перевода на карту/СБП (пусто = способ выключен)
CARD_DETAILS=
